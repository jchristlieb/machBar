# Ignore everything by default
/*

# Re-include directory traversal so whitelisted paths work
!/.gitignore
!/README.md
!/dokumente/

# Inside dokumente: only formulare (Absichtserklärung) and OnePager
dokumente/*
!dokumente/formulare/
!dokumente/praesentation/
dokumente/formulare/*
!dokumente/formulare/absichtserklaerung.pdf
!dokumente/formulare/absichtserklaerung.html
dokumente/praesentation/*
!dokumente/praesentation/OnePager-Kneipe-Wittenberge.pdf

# macOS cruft
.DS_Store
